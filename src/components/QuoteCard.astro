---
interface Props {
  author: string;
  handle?: string;
  date: string;
  url: string;
}

const { author, handle, date, url } = Astro.props;
---

<figure
  class="not-prose font-ibm my-8 pl-4"
  style="border-left: 2px solid #2218d6;"
>
  <blockquote class="text-sm leading-relaxed">
    <slot />
  </blockquote>
  <figcaption class="mt-3 text-xs" style="color: rgb(120, 110, 90);">
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="hover:underline"
    >
      {author}{handle && ` (${handle})`}, {date}
    </a>
  </figcaption>
</figure>
